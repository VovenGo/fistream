APP_ENV=local
APP_BUILD_ID=dev
HTTP_ADDR=:8080
DATABASE_URL=postgres://fistream:fistream@postgres:5432/fistream?sslmode=disable
SERVICE_ACCESS_PASSWORD=change-me
ROOM_TTL=2h
API_TOKEN_SECRET=dev-api-token-secret
