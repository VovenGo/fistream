JITSI_SUBJECT=meet.jitsi
JITSI_TOKEN_TTL=2h
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173
LOG_LEVEL=info

# Jitsi docker stack vars
JITSI_IMAGE_TAG=stable-10888
XMPP_DOMAIN=meet.jitsi
